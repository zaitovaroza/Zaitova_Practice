<Window x:Class="Zaitova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер пол - Учет партнеров" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <DockPanel Margin="0">
        <!-- МЕНЮ ПРОГРАММЫ -->
        <Menu DockPanel.Dock="Top" Background="White" Height="40" Foreground="#333333" 
              BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <MenuItem Header="Файл" Foreground="#333333">
                <MenuItem Header="Выход" Click="ExitMenuItem_Click" Foreground="#333333"/>
            </MenuItem>

            <MenuItem Header="Партнеры" Foreground="#333333">
                <MenuItem Header="Добавить партнера" Click="AddPartnerMenuItem_Click" Foreground="#333333"/>
                <Separator/>
                <MenuItem Header="Редактировать" Click="EditPartnerMenuItem_Click" Foreground="#333333"/>
                <MenuItem Header="Удалить" Click="DeletePartnerMenuItem_Click" Foreground="#333333"/>
            </MenuItem>

            <MenuItem Header="Справка" Foreground="#333333">
                <MenuItem Header="О программе" Click="AboutMenuItem_Click" Foreground="#333333"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <!-- Партнеры - 71% -->
                <ColumnDefinition Width="10"/>
                <!-- Разделитель -->
                <ColumnDefinition Width="1.5*"/>
                <!-- Заказы - 29% -->
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ: ПАРТНЕРЫ -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#E0E0E0" 
                        BorderThickness="1,1,1,0" CornerRadius="5,5,0,0" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ПАРТНЕРЫ" Foreground="#333333" FontWeight="Bold" FontSize="16"/>
                        <Button Grid.Column="1" Content="Добавить" Width="80" Height="30" 
                                Background="#2196F3" BorderThickness="0" Foreground="White"
                                FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                Click="AddPartnerMenuItem_Click"
                                ToolTip="Добавить партнера"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,1,1">
                    <ItemsControl ItemsSource="{Binding Partners}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" Margin="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" 
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Margin="5"
                                        Padding="10"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        MouseLeftButtonUp="PartnerCard_MouseLeftButtonUp">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                                   FontSize="14" FontWeight="Bold" 
                                                   Foreground="#333333"
                                                   Text="{Binding CompanyName}"/>

                                        <Border Grid.Row="0" Grid.Column="1" 
                                                Background="#4CAF50" CornerRadius="15" 
                                                Padding="8,2" Margin="5,0">
                                            <TextBlock Text="{Binding DiscountPercentage, StringFormat='{}{0}%'}" 
                                                       Foreground="White" FontWeight="Bold"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding DirectorFullname}" 
                                                   Foreground="#666666" FontSize="12"
                                                   Margin="0,5,0,2"/>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Phone}" 
                                                       Foreground="#666666" FontSize="12"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                                   Text="{Binding Rating, StringFormat='Рейтинг: {0}'}" 
                                                   Foreground="#FF9800" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- РАЗДЕЛИТЕЛЬ -->
            <GridSplitter Grid.Column="1" 
                          HorizontalAlignment="Stretch" 
                          Background="#E0E0E0" 
                          Width="2"/>

            <!-- ПРАВАЯ ПАНЕЛЬ: ЗАКАЗЫ В ВИДЕ ТАБЛИЦЫ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#E0E0E0" 
                        BorderThickness="1,1,1,0" CornerRadius="5,5,0,0" Padding="10">
                    <TextBlock Text="{Binding SelectedPartner.CompanyName, StringFormat='ЗАКАЗЫ: {0}'}" 
                               Foreground="#333333" FontWeight="Bold" FontSize="16"/>
                </Border>

                <!-- ТАБЛИЦА ЗАКАЗОВ -->
                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding SelectedPartnerOrders}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="White"
                          BorderBrush="#E0E0E0"
                          BorderThickness="1,0,1,1"
                          RowHeight="35"
                          AlternatingRowBackground="#F9F9F9"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">

                    <DataGrid.Columns>
                        <!-- Дата -->
                        <DataGridTextColumn Header="Дата" 
                                            Binding="{Binding FormattedSaleDate}" 
                                            Width="80"
                                            ElementStyle="{StaticResource DataGridCellStyle}"
                                            HeaderStyle="{StaticResource DataGridHeaderStyle}"/>

                        <!-- Товар -->
                        <DataGridTextColumn Header="Товар" 
                                            Binding="{Binding ProductName}" 
                                            Width="*"
                                            ElementStyle="{StaticResource DataGridCellStyle}"
                                            HeaderStyle="{StaticResource DataGridHeaderStyle}"/>

                        <!-- Количество -->
                        <DataGridTextColumn Header="Кол-во" 
                                            Binding="{Binding Quantity}" 
                                            Width="60"
                                            ElementStyle="{StaticResource DataGridCellStyle}"
                                            HeaderStyle="{StaticResource DataGridHeaderStyle}"/>

                        <!-- Сумма -->
                        <DataGridTextColumn Header="Сумма" 
                                            Binding="{Binding FormattedTotalAmount}" 
                                            Width="90"
                                            ElementStyle="{StaticResource DataGridCellStyle}"
                                            HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Сообщение, если нет заказов или не выбран партнер -->
                <Border Grid.Row="1" 
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1,0,1,1"
                        Padding="20"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding SelectedPartnerOrders.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <TextBlock Text="Нет заказов для отображения"
                               FontSize="14" Foreground="#999999" 
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>