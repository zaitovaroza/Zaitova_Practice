<Window x:Class="Zaitova.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История продаж" 
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#333333"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Информация о скидке -->
        <Border Grid.Row="1" 
                Background="#E8F5E9" 
                CornerRadius="5" 
                Padding="15" 
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ИНФОРМАЦИЯ О СКИДКЕ"
                               FontSize="12"
                               Foreground="#4CAF50"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding DiscountInfo}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="#333333"/>
                    <TextBlock Text="{Binding TotalSalesAmount, StringFormat='Общая сумма продаж: {0:N2} ₽'}" 
                               FontSize="14"
                               Foreground="#666666"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#4CAF50"
                        CornerRadius="5"
                        Width="60" Height="60"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding DiscountPercentage}"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Таблица продаж -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding SalesHistory}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  RowHeight="35"
                  AlternatingRowBackground="#F9F9F9"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" 
                                    Binding="{Binding FormattedSaleDate}" 
                                    Width="120"/>

                <DataGridTextColumn Header="Наименование продукции" 
                                    Binding="{Binding ProductName}" 
                                    Width="300"/>

                <DataGridTextColumn Header="Количество" 
                                    Binding="{Binding Quantity}" 
                                    Width="100"/>

                <DataGridTextColumn Header="Сумма" 
                                    Binding="{Binding FormattedTotalAmount}" 
                                    Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Индикатор загрузки -->
        <Grid Grid.Row="2" 
              Background="#80FFFFFF" 
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="50" Height="50" IsIndeterminate="True"/>
                <TextBlock Text="Загрузка истории..." Margin="0,10" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Сообщение, если история пуста -->
        <TextBlock Grid.Row="2" 
                   Text="У данного партнера пока нет продаж"
                   FontSize="16"
                   Foreground="#666666"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding SalesHistory.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
    </Grid>
</Window>